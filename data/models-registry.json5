// Model registry (JSON5)
// Add comments, trailing commas, etc.
[
  {
    id: "google/gemini-3-pro-image-preview",
    name: "Gemini 3 Pro Preview",
    badge: "Great but Expensive",
    description: "'Nano Banana Pro' Good for editing, as it preserves the original image.",
    pricing: "About $0.14 per image",
    // For "Break Comic into Images", prefer Gemini 3.1 Flash: Pro tends to
    // "sanitize" content while extracting (observed repeatedly: it redrew an
    // open-defecation panel onto a porcelain toilet).
    // Google Gemini docs list these ratios for Gemini 3 Pro Image Preview.
    supportedAspectRatios: [
      "2:3",
      "3:4",
      "4:5",
      "9:16",
      "1:1",
      "5:4",
      "4:3",
      "3:2",
      "16:9",
      "21:9",
    ],
    default: false,
  },
  {
    // OpenRouter currently only exposes the "-preview" key. We can NOT pre-list
    // the not-yet-published "google/gemini-3.1-flash-image" as a fallbackId:
    // OpenRouter validates every id in the `models` array up front and rejects
    // the whole request with 400 ("... is not a valid model ID") for any key it
    // doesn't recognize. (The `models` fallback only fails over on runtime
    // errors of *valid* models, not unknown ids.) When OpenRouter retires the
    // preview and republishes the non-preview key, update `id` here.
    id: "google/gemini-3.1-flash-image-preview",
    name: "Gemini 3.1 Flash",
    badge: "Great",
    description: "'Nano Banana 2'. Good for editing, as it preserves the original image. Not quite as good at instruction understanding as Gemini 3 Pro.",
    pricing: "About $0.07 per image",
    // Recommended for "Break Comic into Images": edit-framed cleanup with
    // Flash preserves the original artwork well (Pro tends to sanitize/redraw
    // scenes), and the tool fetches captions in a separate text call, so
    // Flash's one-modality-per-turn limit doesn't matter. Keep reasoning at
    // the model default for that tool — forced reasoning invites redraws.
    // Google Gemini docs note that 3.1 Flash adds the four extreme ratios.
    supportedAspectRatios: [
      "1:8",
      "1:4",
      "2:3",
      "3:4",
      "4:5",
      "9:16",
      "1:1",
      "5:4",
      "4:3",
      "3:2",
      "16:9",
      "21:9",
      "4:1",
      "8:1",
    ],
    initialReasoningLevel: "medium",
    default: true,
  },

  {
    id: "openai/gpt-5-image",
    name: "GPT-5 Image",
    badge: "Good, but only for new images.",
    description: "Slow",
    pricing: "About $0.02 / 1k image",
    // OpenAI docs explicitly call out square, portrait, and landscape popular sizes.
    // The current OpenRouter chat-completions path in this app can faithfully target
    // those three exact aspect ratios.
    supportedAspectRatios: ["2:3", "1:1", "3:2"],
    default: false,
  },
  {
    id: "openai/gpt-5.4-image-2",
    name: "GPT-5.4 Image 2",
    badge: "TODO",
    description: "slower and more expensive than gemini flash",
    pricing: "About $0.24 / 1k image",
    // OpenAI docs explicitly call out square, portrait, and landscape popular sizes.
    // The current OpenRouter chat-completions path in this app can faithfully target
    // those three exact aspect ratios.
    supportedAspectRatios: ["2:3", "1:1", "3:2"],
    default: false,
  },
]
