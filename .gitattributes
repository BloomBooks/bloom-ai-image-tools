# Normalize all text files to LF in the repository, regardless of the
# contributor's OS or git core.autocrlf setting. This eliminates the
# CRLF/LF churn that previously appeared on Windows checkouts.
* text=auto eol=lf

# Treat known binary assets as binary: no line-ending munging, no diffing.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
